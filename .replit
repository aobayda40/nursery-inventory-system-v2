modules = ["nodejs-20"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd nursery-inventory-system/nursery-inventory-system/artifacts/api-server && export NODE_ENV=development && pnpm run prisma:generate && pnpm run build && PORT=8080 SESSION_SECRET=$SESSION_SECRET DATABASE_URL=$DATABASE_URL node --enable-source-maps ./dist/index.mjs"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd nursery-inventory-system/nursery-inventory-system/artifacts/rosemary-nursery && PORT=5000 BASE_PATH=/ API_PORT=8080 pnpm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 19556
externalPort = 3000
